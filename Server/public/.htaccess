# JustLinkIt - URLルーティング
# 前提: このディレクトリ（Server/public/）がWebサーバーのDocumentRootであること。

# セキュリティヘッダー（多層防御）。
# 本アプリは同一オリジンの<script src>/<link>のみで完結し、外部CDNやインラインscript/styleを
# 使わない構成のため、default-src 'self' の厳格なCSPで問題なく動作する。
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Content-Security-Policy "default-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
</IfModule>

RewriteEngine On

# mod_php/php-fpm + リバースプロキシ構成のホスト（例: XServer）では、Authorizationヘッダーが
# PHPまで転送されずに欠落することがある（$_SERVERにもgetallheaders()にも現れない）。
# upload_api_key認証（api/upload.php）が機能するために、環境変数経由で明示的に転送する。
RewriteCond %{HTTP:Authorization} .
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# 既に実ファイルが存在するリクエスト（例: /u/{hash}.png の画像直リンク）はそのまま静的配信する。
RewriteCond %{REQUEST_FILENAME} !-f

# 拡張子なしの /{アップロードディレクトリ}/{64桁ハッシュ値}（動画のみ）を viewer.php にルーティングする。
# ディレクトリ名は config.php の upload_dir に依存するためハードコードせず、
# 「1階層のディレクトリ名 + 64桁16進数ハッシュ」というパターンのみで判定する
# （ハッシュ値そのものが十分な長さのランダム性を持つため、これが安全性の境界となる）。
RewriteRule ^[^/]+/([0-9a-f]{64})$ viewer.php?hash=$1 [L,QSA]
