<tb:TaskbarIcon x:Class="JustLinkIt.Client.Views.TrayIcon"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:tb="http://www.hardcodet.net/taskbar"
                ToolTipText="JustLinkIt">
    <tb:TaskbarIcon.ContextMenu>
        <ContextMenu>
            <MenuItem Header="ファイルを選択してアップロード" Click="UploadFile_Click" />
            <MenuItem Header="クリップボードの画像をアップロード" Command="{Binding UploadFromClipboardCommand}" />
            <Separator />
            <MenuItem Header="設定..." Click="OpenSettings_Click" />
            <Separator />
            <MenuItem Header="終了" Command="{Binding ExitCommand}" />
        </ContextMenu>
    </tb:TaskbarIcon.ContextMenu>
</tb:TaskbarIcon>
